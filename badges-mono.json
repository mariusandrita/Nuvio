{
  "filters": [
    {
      "id": "src-rd-cached",
      "groupId": "gsrc",
      "type": "filter",
      "name": "RD⚡",
      "pattern": "\\[RD⚡\\]",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/rd-logo.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "src-rd-dl",
      "groupId": "gsrc",
      "type": "filter",
      "name": "RD⬇️",
      "pattern": "\\[RD⬇️\\]",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/rd-download.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "src-torrent",
      "groupId": "gsrc",
      "type": "filter",
      "name": "🧲",
      "pattern": "\\[TORRENT🧲\\]",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/down-icon.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "src-local",
      "groupId": "gsrc",
      "type": "filter",
      "name": "📁",
      "pattern": "📁 LocalHub",
      "isEnabled": true,
      "imageURL": "",
      "tagColor": "#33FF9800",
      "borderColor": "#FFFF9800",
      "textColor": "#FF9800",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "res-4k",
      "groupId": "gr",
      "type": "filter",
      "name": "4K",
      "pattern": "(?i)\\b(4320[pi]?|2160[pi]?|4k|u(ltra)?[ ._-]?hd)\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/4k.png",
      "tagColor": "#33FFFFFF",
      "borderColor": "#FF858283",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "res-1080p",
      "groupId": "gr",
      "type": "filter",
      "name": "1080p",
      "pattern": "(?i)\\b(1080[pi]?)\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/1080p.png",
      "tagColor": "#33FFFFFF",
      "borderColor": "#FF858283",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "res-720p",
      "groupId": "gr",
      "type": "filter",
      "name": "720p",
      "pattern": "(?i)\\b(720[pi]?)\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/720p.png",
      "tagColor": "#33FFFFFF",
      "borderColor": "#FF858283",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "aud-atmos",
      "groupId": "ga",
      "type": "filter",
      "name": "Atmos",
      "pattern": "(?i)\\batmos\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/atmos.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "aud-truehd",
      "groupId": "ga",
      "type": "filter",
      "name": "TrueHD",
      "pattern": "(?i)\\btruehd\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/truehd.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "aud-dtsx",
      "groupId": "ga",
      "type": "filter",
      "name": "DTS:X",
      "pattern": "(?i)\\bdts[-. ]?x\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/dtsx.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "aud-dtshdma",
      "groupId": "ga",
      "type": "filter",
      "name": "DTS-HD MA",
      "pattern": "(?i)\\bdts[-. ]?hd[-. ]?ma\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/dtshdma.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "aud-ddp",
      "groupId": "ga",
      "type": "filter",
      "name": "DD+",
      "pattern": "(?i)\\b(dd[p+]|e[-]?ac[-]?3|eac3)\\b",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/digitalplus.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "aud-dts",
      "groupId": "ga",
      "type": "filter",
      "name": "DTS",
      "pattern": "(?i)(?<!-)\\bdts\\b(?![-. ]?(hd|x|ma))",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/dts.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-ro",
      "groupId": "gl",
      "type": "filter",
      "name": "🇷🇴",
      "pattern": "(?i)\\b(romanian|rom|ron)\\b|🇷🇴",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-ro.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-en",
      "groupId": "gl",
      "type": "filter",
      "name": "🇬🇧",
      "pattern": "(?i)\\b(english|eng)\\b|🇬🇧|🇺🇸",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-en.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-es",
      "groupId": "gl",
      "type": "filter",
      "name": "🇪🇸",
      "pattern": "(?i)\\b(spanish|spa|esp)\\b|🇪🇸|🇲🇽",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-es.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-fr",
      "groupId": "gl",
      "type": "filter",
      "name": "🇫🇷",
      "pattern": "(?i)\\b(french|fre|fra)\\b|🇫🇷",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-fr.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-de",
      "groupId": "gl",
      "type": "filter",
      "name": "🇩🇪",
      "pattern": "(?i)\\b(german|ger|deu)\\b|🇩🇪",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-de.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-it",
      "groupId": "gl",
      "type": "filter",
      "name": "🇮🇹",
      "pattern": "(?i)\\b(italian|ita)\\b|🇮🇹",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-it.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-ja",
      "groupId": "gl",
      "type": "filter",
      "name": "🇯🇵",
      "pattern": "(?i)\\b(japanese|jpn)\\b|🇯🇵",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-ja.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-ko",
      "groupId": "gl",
      "type": "filter",
      "name": "🇰🇷",
      "pattern": "(?i)\\b(korean|kor)\\b|🇰🇷",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-ko.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    },
    {
      "id": "lang-multi",
      "groupId": "gl",
      "type": "filter",
      "name": "🌐",
      "pattern": "(?i)\\b(multi|multilingual|multiple)\\b|🌐",
      "isEnabled": true,
      "imageURL": "https://raw.githubusercontent.com/mariusandrita/Nuvio/main/images/flag-multi.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#FFFFFF",
      "tagStyle": "filled and bordered"
    }
  ],
  "groups": [
    {
      "id": "gsrc",
      "type": "group",
      "name": "Source",
      "filters": ["src-rd-cached", "src-rd-dl", "src-torrent", "src-local"]
    },
    {
      "id": "gr",
      "type": "group",
      "name": "Resolution",
      "filters": ["res-4k", "res-1080p", "res-720p"]
    },
    {
      "id": "ga",
      "type": "group",
      "name": "Audio",
      "filters": ["aud-atmos", "aud-truehd", "aud-dtsx", "aud-dtshdma", "aud-ddp", "aud-dts"]
    },
    {
      "id": "gl",
      "type": "group",
      "name": "Language",
      "filters": ["lang-ro", "lang-en", "lang-es", "lang-fr", "lang-de", "lang-it", "lang-ja", "lang-ko", "lang-multi"]
    }
  ]
}
